# Rename this file to ".env" (remove the ".example") and fill in your own key.
# NEVER commit or share the real .env file — it contains a secret credential.

# Option 1 (recommended, free, no credit card): Groq
# Get a key at https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key-here

# Option 2: Google Gemini (create via https://aistudio.google.com/apikey,
# NOT console.cloud.google.com, or you may get a 0-quota key)
# GOOGLE_API_KEY=your-google-api-key-here

# Option 3: Claude/Anthropic
# ANTHROPIC_API_KEY=your-anthropic-api-key-here
